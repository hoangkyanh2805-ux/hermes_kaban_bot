# Hermes Content Pipeline — Environment Variables
# Copy to .env for local reference. On Railway, configure via web UI + service env.
# NEVER commit real values.

# ── Railway / Hermes Gateway ──────────────────────────────────────────
PORT=8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                    # Generated on first deploy if unset

# ── LLM Provider (tutorial uses DeepSeek) ─────────────────────────────
DEEPSEEK_API_KEY=                  # Primary tutorial provider
# OPENROUTER_API_KEY=              # Alternative — any Hermes-supported provider

# ── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                # From @BotFather
# TELEGRAM_ALLOWED_USERS=          # Comma-separated user IDs (recommended)

# ── TinyFish (research agent) ─────────────────────────────────────────
TINYFISH_API_KEY=                  # https://agent.tinyfish.ai/api-keys

# ── Supabase (all write agents via skill) ─────────────────────────────
SUPABASE_URL=                      # Project URL — https://supabase.plug.dev/ykdVN09
SUPABASE_SERVICE_ROLE_KEY=         # Service role — agents only, RLS-scoped
# SUPABASE_ANON_KEY=               # Optional — human read-only dashboard

# ── Kanban (set by dispatcher — informational only) ───────────────────
# HERMES_KANBAN_BOARD=default
# _KANBAN_TASK=                    # Injected into worker env at spawn

# ── Data paths (Railway) ──────────────────────────────────────────────
# Hermes state, Kanban DB, skills persist on volume mounted at /data
